}

setup_conky () {
############### Install Conky/Settings and Widget Apps
    ##### Install Packages
    ##### conky-all - main conky system
    ##### vnstat - network statistics
    ##### psensor - graphical sensor monitor
    ##### tree - helps determine system monitors for conky
    sudo nala install conky-all vnstat psensor tree -y 2>&1

    clear
    echo ""
    PS3="Select the conky file to use: "

    clear
    echo "" 2>&1 | tee -a $LOG
    echo "" 2>&1 | tee -a $LOG

    select opt in vm e6530 macbookpro macpro quit; do

      case $opt in
        vm)
          cp $INSTALL_PATH/configs/conky/.conkyrc_vm ~/.conkyrc 2>&1 | tee -a $LOG
          break
          ;;
        e6530)
          cp $INSTALL_PATH/configs/conky/.conkyrc_e6530 ~/.conkyrc 2>&1 | tee -a $LOG
          break
          ;;
        macbookpro)
          cp $INSTALL_PATH/configs/conky/.conkyrc_macbookpro ~/.conkyrc 2>&1 | tee -a $LOG
          break
          ;;
        macpro)
          cp $INSTALL_PATH/configs/conky/.conkyrc_macpro ~/.conkyrc 2>&1 | tee -a $LOG
          break
          ;;
        quit)
          break
          ;;
        *)
          echo "Invalid option $REPLY" 2>&1 | tee -a $LOG
          ;;
      esac
    done

    cp $INSTALL_PATH/configs/autostart/conky.desktop ~/.config/autostart/ 2>&1 | tee -a $LOG

    sudo cp $INSTALL_PATH/configs/conky/sun-hours_etc_cron.daily /etc/cron.daily/sun-hours 2>&1 | tee -a $LOG
    sudo chown root:root /etc/cron.daily/sun-hours 2>&1 | tee -a $LOG 
    sudo chmod 755 /etc/cron.daily/sun-hours 2>&1 | tee -a $LOG

    sudo cp $INSTALL_PATH/configs/conky/sun-hours_usr_local_bin /usr/local/bin/sun-hours 2>&1 | tee -a $LOG
    sudo chown root:root /usr/local/bin/sun-hours 2>&1 | tee -a $LOG
    sudo chmod 755 /usr/local/bin/sun-hours 2>&1 | tee -a $LOG

    echo "" 2>&1 | tee -a $LOG
    echo "" 2>&1 | tee -a $LOG
    echo Getting current Sunset and Sunrise times...  Please be patient... 2>&1 | tee -a $LOG
    sudo /usr/local/bin/sun-hours 2>&1 | tee -a $LOG
    sleep 10
}

setup_grub () {
############### Configure Grub For Single Boot / Dual Boot
    clear
    echo ""
    PS3=" Select the current OS: "

    clear
    echo "" 2>&1 | tee -a $LOG
    echo "" 2>&1 | tee -a $LOG

    select opt in LMDE MINT QUIT; do

      case $opt in
        LMDE)
          echo "" 2>&1 | tee -a $LOG
          echo  Modifying Grub Menu to not display...  Please be patient... 2>&1 | tee -a $LOG
          echo "" 2>&1 | tee -a $LOG
          echo "" 2>&1 | tee -a $LOG
          sudo sed -i 's/GRUB_TIMEOUT=5/GRUB_TIMEOUT=0/g' /etc/default/grub 2>&1 | tee -a $LOG
          sudo update-grub 2>&1 | tee -a $LOG
          sleep 2
          break
          ;;
        MINT)
          echo "" 2>&1 | tee -a $LOG
          echo " NOTICE: MINT is set to 0 Timeout by Default...  No changes necessary..." 2>&1 | tee -a $LOG
          sleep 3
          break
          ;;
        QUIT)
          break
          ;;
        *)
          echo "Invalid option $REPLY" 2>&1 | tee -a $LOG
          ;;
      esac
    done
    sleep 5
}

ppa_connect () {
    if whiptail --title "Connect to NAS Server" --yesno "Connect to PPA (Personal Package Archive)?" 8 78; then
	
        NAS_USER=$(whiptail --inputbox "Enter NAS User" 8 39 --title "NAS User" 3>&1 1>&2 2>&3)
        exitstatus=$?
        if [ $exitstatus = 0 ]; then
            echo "NAS User entered as " $NAS_USER
        else
            echo "User selected Cancel."
        fi
        echo "(Exit status was $exitstatus)"

        NAS_IP=$(whiptail --inputbox "Enter NAS IP" 8 39 --title "NAS IP" 3>&1 1>&2 2>&3)
        exitstatus=$?
        if [ $exitstatus = 0 ]; then
            echo "NAS IP entered as " $NAS_IP
        else
            echo "User selected Cancel."
        fi
        echo "(Exit status was $exitstatus)"

        NAS_SHARE=$(whiptail --inputbox "Enter NAS Share" 8 39 --title "NAS Share" 3>&1 1>&2 2>&3)
        exitstatus=$?
        if [ $exitstatus = 0 ]; then
            echo "NAS Share entered as " $NAS_SHARE
        else
            echo "User selected Cancel."
        fi
        echo "(Exit status was $exitstatus)"

        NAS_PASS=$(whiptail --passwordbox "Please enter your NAS Password" 8 78 --title "NAS Password" 3>&1 1>&2 2>&3)
        exitstatus=$?
        if [ $exitstatus == 0 ]; then
            echo "User selected Ok and entered password"
        else
            echo "User selected Cancel."
        fi
        echo "(Exit status was $exitstatus)"

        if whiptail --title "Are NAS Connection Settings Correct?" --yesno " NAS User = $NAS_USER \n NAS IP = $NAS_IP \n NAS Share = $NAS_SHARE " 11 78; then
            clear
            echo ""
            echo ""
            echo " Please be patient while PPA - Personal Package Archive is downloaded to packages folder"
            echo ""
            cd packages/
            smbget -R smb://$NAS_IP/$NAS_SHARE/build_mint/packages/ --user $NAS_USER%$NAS_PASS
            sleep 5
            clear
        else
            echo "User selected No, exit status was $?."
        fi

    ### PPA INSTALL VIRTUALBOX
    if whiptail --title "Install VirtualBox" --yesno "Install VirtualBox?" 8 78; then
        ppa_install_virtualbox
    else
