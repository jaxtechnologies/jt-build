    ##### alacritty - terminal 
    ##### xwallpaper - background set app
    ##### nitrogen - background chooser
    ##### picom -transparency compositor
    sudo nala install xmonad xmobar alacritty xwallpaper nitrogen picom -y 2>&1
    [ ! -d ~/.config/xmobar ] && mkdir -p ~/.config/xmobar
